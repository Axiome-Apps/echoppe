{
  "name": "@echoppe/api",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --env-file=.env run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun --env-file=../../.env run dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@echoppe/core": "workspace:*",
    "@echoppe/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "elysia": "^1.4.29",
    "elysia-rate-limit": "^4.6.2",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "6.0.3"
  }
}
