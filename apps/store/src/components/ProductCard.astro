---
import { formatPrice, mediaUrl } from '../lib/api';

interface Props {
  name: string;
  slug: string;
  price?: string | number | null;
  imageId?: string | null;
}

const { name, slug, price, imageId } = Astro.props;
const image = mediaUrl(imageId);
---

<a href={`/produits/${slug}`} class="group block">
  <div class="aspect-square overflow-hidden rounded-lg bg-zinc-100">
    {
      image ? (
        <img
          src={image}
          alt={name}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-zinc-300">Pas d'image</div>
      )
    }
  </div>
  <h3 class="mt-3 text-sm font-medium text-zinc-900">{name}</h3>
  {price != null && <p class="mt-1 text-sm text-zinc-600">{formatPrice(price)}</p>}
</a>
