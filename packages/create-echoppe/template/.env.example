# Référence des variables — `create-echoppe` génère un vrai .env à la création.
# Docker Compose lit ce .env automatiquement (valeurs du backend).

# ─── Front (Astro + SDK) ────────────────────────────────────────────────
# URL de l'API interrogée par la boutique (SSR + images).
PUBLIC_API_URL=http://localhost:7532

# ─── Version des images Échoppe (backend, cf. compose.yaml) ─────────────
ECHOPPE_VERSION=latest

# ─── Base de données ────────────────────────────────────────────────────
POSTGRES_USER=echoppe
POSTGRES_PASSWORD=echoppe
POSTGRES_DB=echoppe

# ─── Ports exposés sur l'hôte ───────────────────────────────────────────
API_PORT=7532
ADMIN_PORT=3211

# URL publique du front, transmise à l'API (CORS / liens absolus).
STORE_URL=http://localhost:4321

# ─── Compte admin — À RENSEIGNER avant le premier `docker compose up` ────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Clé de chiffrement (secrets stockés). Générer : openssl rand -base64 32
ENCRYPTION_KEY=
