---
import Layout from '../../layouts/Layout.astro';
import { api, formatPrice, mediaUrl } from '../../lib/api';

const { slug } = Astro.params;

const { data: product } = await api.products.bySlug({
  params: { path: { slug: slug ?? '' } },
});

if (!product) {
  Astro.response.status = 404;
}

const image = mediaUrl(product?.featuredImage);
const price = product?.variants?.[0]?.priceHt;
---

<Layout title={product ? `${product.name} — Boutique Échoppe` : 'Produit introuvable'}>
  {
    product ? (
      <div class="grid gap-10 md:grid-cols-2">
        <div class="aspect-square overflow-hidden rounded-lg bg-zinc-100">
          {image ? (
            <img src={image} alt={product.name} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full w-full items-center justify-center text-zinc-300">
              Pas d'image
            </div>
          )}
        </div>

        <div>
          <a href="/produits" class="text-sm text-zinc-500 hover:text-zinc-900">← Produits</a>
          <h1 class="mt-2 text-3xl font-bold">{product.name}</h1>
          {price != null && <p class="mt-3 text-2xl text-zinc-800">{formatPrice(price)}</p>}
          {product.description && (
            <p class="mt-6 whitespace-pre-line leading-relaxed text-zinc-600">
              {product.description}
            </p>
          )}
        </div>
      </div>
    ) : (
      <div class="py-20 text-center">
        <h1 class="text-2xl font-bold">Produit introuvable</h1>
        <a href="/produits" class="mt-4 inline-block text-zinc-600 hover:text-zinc-900">
          Retour aux produits
        </a>
      </div>
    )
  }
</Layout>
