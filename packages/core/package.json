{
  "name": "@echoppe/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema/index.ts"
  },
  "scripts": {
    "test": "bun test src",
    "type-check": "tsc --noEmit",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "db:seed": "bun --env-file=../../.env src/db/seed.ts"
  },
  "dependencies": {
    "@echoppe/shared": "workspace:*",
    "@getbrevo/brevo": "6",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "9",
    "postgres": "^3.4.9",
    "resend": "^6.17.1",
    "stripe": "22"
  },
  "devDependencies": {
    "@types/nodemailer": "8",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.3"
  }
}
